{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "docs/agents/agent-rules.md",
    "docs/agents/sdk-conventions.md",
    "docs/agents/tui-conventions.md",
    "docs/agents/pitfalls.md"
  ],
  "permission": {
    "bash": {
      "*": "allow",
