FROM golang:1.26-alpine AS builder
WORKDIR /src
COPY go.mod go.sum ./
COPY sdk/go.mod sdk/go.sum ./sdk/
COPY datefield/go.mod datefield/go.sum ./datefield/
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -ldflags="-s -w" -o /pbmate .

FROM alpine:3.21
WORKDIR /env
COPY --from=builder /pbmate /usr/local/bin/pbmate
ENTRYPOINT ["pbmate"]
